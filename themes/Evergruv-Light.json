// VS Code color scheme definition for the theme Evergruv
//
// REF https://github.com/georglauterbach/evergruv
//     https://code.visualstudio.com/api/references/theme-color
{
  "$schema": "vscode://schemas/color-theme",
  "type": "light",
  // ! SEMANTIC HIGHLIGHTING
  "semanticHighlighting": true,
  "semanticTokenColors": {
    // * -- standard token types
    // REF https://code.visualstudio.com/api/language-extensions/semantic-highlight-guide#standard-token-types-and-modifiers
    "namespace": "#35A77C",
    "class": "#3A94C5",
    "enum": "#3A94C5",
    "interface": {
      "foreground": "#3A94C5",
      "italic": true
    },
    "struct": "#3A94C5",
    "typeParameter": "#F57D26",
    "type": "#3A94C5",
    "parameter": "#5C6A72",
    "variable": "#5C6A72",
    "property": "#5C6A72",
    "enumMember": "#5C6A72",
    "decorator": "#8DA101",
    "event": "#35A77C",
    "function": "#8DA101",
    "function.async": {
      "italic": true
    },
    "method": "#8DA101",
    "method.async": {
      "italic": true
    },
    "macro": "#DF69BA",
    "label": "#DF69BA",
    "comment": "#5C6A72A0", // ~~~
    "string": "#D69A00",
    "keyword": "#F85552",
    "number": "#5C6A72",
    "regexp": "#F57D26",
    "operator": "#F57D26",
    // * -- custom token types
    "boolean": {
      "foreground": "#5C6A72",
      "italic": true
    },
    "builtinAttribute": "#F85552",
    "builtinType": "#3A94C5",
    "const": "#5C6A72",
    "*.deprecated": {
      "strikethrough": true
    },
    "*.documentation": {
      "bold": true,
      "italic": false
    },
    "formatSpecifier": "#F57D26",
    "key": "#DF69BA",
    "static": "#5C6A72",
    "table": "#35A77C",
    "typeAlias": "#3A94C5",
    // * -- language-specific token types
    // Rust
    "derive:rust": "#DF69BA",
    "deriveHelper:rust": "#5C6A72",
    "generic:rust": "#5C6A72",
    "lifetime:rust": "#F57D26",
  },
  // ! WORKBENCH
  "colors": {
    "foreground": "#5C6A72E0",
    "descriptionForeground": "#5C6A72E0",
    "focusBorder": "#8DA101",
    // ! Activity Bar
    //   -- note: contains symbols for file explorer, search, etc.
    "activityBar.background": "#F5F5F2",
    "activityBar.foreground": "#5C6A72",
    "activityBar.activeBackground": "#00000000",
    "activityBar.activeFocusBorder": "#00000000",
    "activityBar.activeBorder": "#00000000",
    "activityBar.inactiveForeground": "#5C6A7260",
    "activityBarBadge.background": "#8DA101",
    "activityBarBadge.foreground": "#EBEBE4",
    // ! Badges
    "badge.background": "#8DA101",
    "badge.foreground": "#EBEBE4",
    // ! Buttons
    "button.background": "#8DA101E0",
    "button.foreground": "#EBEBE4",
    "button.border": "#8DA10180",
    "button.hoverBackground": "#8DA101",
    "button.secondaryBackground": "#EBEBE4",
    "button.secondaryForeground": "#5C6A72",
    "button.secondaryBorder": "#8DA10180",
    "button.secondaryHoverBackground": "#F5F5F2",
    "button.separator": "#00000000",
    // ! Charts
    "charts.foreground": "#5C6A72",
    "charts.blue": "#3A94C5",
    "charts.green": "#8DA101",
    "charts.orange": "#F57D26",
    "charts.purple": "#DF69BA",
    "charts.red": "#F85552",
    "charts.yellow": "#D69A00",
    // ! Checkboxes
    "checkbox.background": "#EBEBE4",
    "checkbox.border": "#5C6A7280",
    "checkbox.foreground": "#8DA101",
    // ! Debugging
    // * -- editor
    "editor.stackFrameHighlightBackground": "#8DA10120",
    // * -- bar icons
    "debugIcon.startForeground": "#8DA101",
    "debugIcon.continueForeground": "#3A94C5",
    "debugIcon.pauseForeground": "#3A94C5",
    "debugIcon.stepIntoForeground": "#3A94C5",
    "debugIcon.stepOutForeground": "#3A94C5",
    "debugIcon.stepBackForeground": "#3A94C5",
    "debugIcon.stepOverForeground": "#3A94C5",
    "debugIcon.restartForeground": "#35A77C",
    "debugIcon.stopForeground": "#F85552",
    "debugIcon.disconnectForeground": "#DF69BA",
    // * -- breakpoints
    "debugIcon.breakpointUnverifiedForeground": "#F85552",
    "debugIcon.breakpointDisabledForeground": "#5C6A72",
    "debugIcon.breakpointForeground": "#8DA101",
    // * -- console
    "debugConsole.infoForeground": "#3A94C5",
    "debugConsole.warningForeground": "#D69A00",
    "debugConsole.errorForeground": "#F85552",
    "debugConsole.sourceForeground": "#5C6A72",
    // * -- tokens
    "debugTokenExpression.boolean": "#5C6A72",
    "debugTokenExpression.error": "#F85552",
    "debugTokenExpression.name": "#5C6A72",
    "debugTokenExpression.number": "#DF69BA",
    "debugTokenExpression.string": "#8DA101",
    "debugTokenExpression.value": "#5C6A72",
    "debugTokenExpression.type": "#35A77C",
    // ! Dropdown Menus
    "dropdown.background": "#EBEBE4",
    "dropdown.border": "#8DA10180",
    "dropdown.foreground": "#5C6A72",
    // ! Editor
    // * -- core
    "editor.background": "#F5F5F2",
    "editor.foreground": "#5C6A72", // applies to all editor windows
    "editorCursor.foreground": "#3A94C5", // cursor color
    "editorWhitespace.foreground": "#5C6A7220", // whitespace indicator color
    "editorLightBulb.foreground": "#D69A00", // light bulb color
    "editorLink.activeForeground": "#8DA101", // CTRL+mouse -> go to definition / declaration
    // * -- sticky scroll
    "editorStickyScroll.shadow": "#5C6A7220", // ~~~
    // * -- active lines & line numbers
    "editor.lineHighlightBackground": "#5C6A720A",
    "editor.inactiveLineHighlightBackground": "#5C6A7208",
    "editorLineNumber.activeForeground": "#5C6A72C0",
    "editorLineNumber.foreground": "#5C6A7260", // ~~~
    // * -- highlights
    // * -- -- same Word
    "editor.wordHighlightBackground": "#5C6A720C",
    "editor.wordHighlightStrongBackground": "#5C6A7220",
    // * -- -- selections
    "editor.selectionBackground": "#5C6A7220",
    "editor.selectionHighlightBackground": "#5C6A720C",
    "editor.inactiveSelectionBackground": "#5C6A720A",
    // * -- -- hover
    "editor.hoverHighlightBackground": "#5C6A7220",
    // * -- -- search (& replace)
    "editor.findMatchBackground": "#5C6A7220", // ~~~
    "editor.findMatchHighlightBackground": "#5C6A720C", // ~~~
    "editor.rangeHighlightBackground": "#8DA10120",
    "editor.findRangeHighlightBackground": "#8DA10120",
    // * -- -- brackets
    "editorBracketHighlight.foreground1": "#5C6A72",
    "editorBracketHighlight.foreground2": "#5C6A72",
    "editorBracketHighlight.foreground3": "#5C6A72",
    "editorBracketHighlight.foreground4": "#5C6A72",
    "editorBracketHighlight.foreground5": "#5C6A72",
    "editorBracketHighlight.foreground6": "#5C6A72",
    "editorBracketMatch.background": "#5C6A7260",
    "editorBracketMatch.border": "#00000000",
    "editorBracketPairGuide.activeBackground1": "#D69A00",
    "editorBracketPairGuide.activeBackground2": "#8DA101",
    "editorBracketPairGuide.activeBackground3": "#35A77C",
    "editorBracketPairGuide.activeBackground4": "#3A94C5",
    "editorBracketPairGuide.activeBackground5": "#DF69BA",
    "editorBracketPairGuide.activeBackground6": "#3A94C5",
    "editorBracketHighlight.unexpectedBracket.foreground": "#F85552",
    // * -- breadcrumbs
    "breadcrumb.background": "#F5F5F2",
    "breadcrumb.foreground": "#5C6A72C0",
    "breadcrumb.focusForeground": "#5C6A72E0",
    "breadcrumb.activeSelectionForeground": "#5C6A72",
    "breadcrumbPicker.background": "#EBEBE4",
    // * -- hints, ..., warnings, error
    "editorHint.foreground": "#8DA101",
    "editorInfo.background": "#00000000",
    "editorInfo.foreground": "#3A94C5",
    "editorWarning.background": "#00000000",
    "editorWarning.foreground": "#D69A00",
    "editorError.background": "#00000000",
    "editorError.foreground": "#F85552",
    // * -- groups (of tabs)
    "editorGroupHeader.tabsBackground": "#EBEBE4",
    "editorGroupHeader.noTabsBackground": "#EBEBE4",
    "editorGroupHeader.border": "#F5F5F2",
    "editorGroupHeader.tabsBorder": "#F5F5F2",
    "editorGroup.border": "#00000000",
    "editorGroup.focusedEmptyBorder": "#8DA10180",
    "editorGroup.dropBackground": "#8DA10120",
    // * -- tabs
    "tab.border": "#00000000",
    "tab.activeBackground": "#F5F5F2",
    "tab.activeForeground": "#5C6A72",
    "tab.inactiveBackground": "#EBEBE4",
    "tab.inactiveForeground": "#5C6A72A0",
    "tab.hoverBackground": "#EBEBE4",
    "tab.hoverForeground": "#5C6A72",
    "tab.unfocusedActiveBackground": "#F5F5F2",
    "tab.unfocusedActiveForeground": "#5C6A7280",
    "tab.unfocusedHoverBackground": "#EBEBE4",
    "tab.unfocusedHoverForeground": "#5C6A72",
    "tab.unfocusedInactiveForeground": "#5C6A7280",
    // * -- gutters (contains line numbers and other symbols)
    "editorGutter.background": "#F5F5F2",
    "editorGutter.addedBackground": "#8DA101C0",
    "editorGutter.addedSecondaryBackground": "#8DA101C0",
    "editorGutter.deletedBackground": "#F85552C0",
    "editorGutter.deletedSecondaryBackground": "#F85552C0",
    "editorGutter.modifiedBackground": "#3A94C5C0",
    "editorGutter.modifiedSecondaryBackground": "#3A94C5C0",
    // * -- hovers (references)
    "editorHoverWidget.background": "#EBEBE4",
    "editorHoverWidget.foreground": "#5C6A72",
    "editorHoverWidget.border": "#8DA10180",
    // * -- suggest widget
    "editorSuggestWidget.background": "#EBEBE4",
    "editorSuggestWidget.foreground": "#5C6A72",
    "editorSuggestWidget.border": "#8DA10180",
    // * -- widgets (e.g. search & replace)
    "editorWidget.background": "#EBEBE4",
    "editorWidget.border": "#8DA10180",
    "editorWidget.foreground": "#5C6A72",
    "widget.border": "#5C6A720C",
    "widget.shadow": "#00000000",
    // * -- minimap
    "minimap.infoHighlight": "#3A94C5C0",
    "minimap.warningHighlight": "#D69A00C0",
    "minimap.errorHighlight": "#F85552C0",
    "minimap.findMatchHighlight": "#5C6A72E0",
    "minimap.selectionHighlight": "#5C6A7240",
    "minimapGutter.addedBackground": "#8DA101E0",
    "minimapGutter.deletedBackground": "#F85552E0",
    "minimapGutter.modifiedBackground": "#3A94C5E0",
    // * -- scroll bar (top)
    "scrollbar.background": "#00000000",
    "scrollbar.shadow": "#EBEBE4A0",
    // * -- scroll bar slider
    "scrollbarSlider.background": "#5C6A7240",
    "scrollbarSlider.hoverBackground": "#8DA10140",
    "scrollbarSlider.activeBackground": "#8DA10160",
    // * -- peek view (top to bottom, left to right)
    "peekView.border": "#8DA10180",
    "peekViewTitle.background": "#EBEBE4",
    "peekViewTitleLabel.foreground": "#5C6A72",
    "peekViewTitleDescription.foreground": "#5C6A72",
    "peekViewEditorGutter.background": "#EBEBE4",
    "peekViewEditor.background": "#EBEBE4",
    "peekViewResult.background": "#EBEBE4",
    "peekViewEditor.matchHighlightBackground": "#5C6A7240",
    "peekViewResult.lineForeground": "#5C6A72C0",
    "peekViewResult.fileForeground": "#5C6A72",
    "peekViewResult.matchHighlightBackground": "#00000000",
    "peekViewResult.selectionBackground": "#00000000",
    "peekViewResult.selectionForeground": "#5C6A72",
    // * -- inline hints
    "editorInlayHint.background": "#00000000",
    "editorInlayHint.foreground": "#5C6A7260",
    "editorInlayHint.parameterBackground": "#00000000",
    "editorInlayHint.parameterForeground": "#5C6A7260",
    "editorInlayHint.typeBackground": "#00000000",
    "editorInlayHint.typeForeground": "#5C6A7260",
    // * -- rulers (vertical lines after X characters)
    "editorRuler.foreground": "#5C6A720C",
    // ! git
    // * -- diff editor
    "diffEditor.diagonalFill": "#5C6A7280",
    "diffEditor.insertedTextBackground": "#8DA10120",
    "diffEditor.insertedLineBackground": "#8DA10120",
    "diffEditor.removedTextBackground": "#F8555220",
    "diffEditor.removedLineBackground": "#F8555220",
    // * -- resource decorations
    "gitDecoration.ignoredResourceForeground": "#5C6A72C0", // ~~~
    "gitDecoration.untrackedResourceForeground": "#8DA101",
    "gitDecoration.addedResourceForeground": "#8DA101",
    "gitDecoration.modifiedResourceForeground": "#3A94C5",
    "gitDecoration.stageModifiedResourceForeground": "#3A94C5",
    "gitDecoration.renamedResourceForeground": "#35A77C",
    "gitDecoration.deletedResourceForeground": "#F85552",
    "gitDecoration.stageDeletedResourceForeground": "#F85552",
    "gitDecoration.conflictingResourceForeground": "#DF69BA",
    "gitDecoration.submoduleResourceForeground": "#5C6A72",
    // ! Icons
    "icon.foreground": "#5C6A72E0",
    // ! Input
    "input.background": "#00000000",
    "input.foreground": "#5C6A72",
    "input.border": "#5C6A7280",
    "input.placeholderForeground": "#5C6A7280",
    "inputOption.activeBackground": "#8DA101",
    "inputOption.activeBorder": "#00000000",
    "inputOption.activeForeground": "#EBEBE4",
    "inputOption.hoverBackground": "#8DA10140",
    "inputValidation.infoBackground": "#00000000",
    "inputValidation.infoForeground": "#3A94C5",
    "inputValidation.infoBorder": "#00000000",
    "inputValidation.warningBackground": "#00000000",
    "inputValidation.warningForeground": "#D69A00",
    "inputValidation.warningBorder": "#00000000",
    "inputValidation.errorBackground": "#00000000",
    "inputValidation.errorForeground": "#3A94C5",
    "inputValidation.errorBorder": "#00000000",
    // ! Links
    "textLink.foreground": "#5C6A72C0",
    "textLink.activeForeground": "#8DA101",
    // ! Lists
    //   -- note: especially important for the file explorer
    "list.warningForeground": "#D69A00",
    "list.errorForeground": "#F85552",
    "list.dropBackground": "#8DA10120",
    "list.invalidItemForeground": "#F85552",
    "tree.indentGuidesStroke": "#5C6A7280",
    // color that shows the already present text match
    "list.highlightForeground": "#8DA101",
    // hover
    "list.hoverBackground": "#8DA10120",
    "list.hoverForeground": "#5C6A72",
    // focus on the list::selection (not the active editor item)
    "list.focusBackground": "#F5F5F2",
    "list.focusForeground": "#5C6A72",
    "list.focusOutline": "#00000000",
    // focus on the list::active item in the editor
    "list.activeSelectionBackground": "#F5F5F2",
    "list.activeSelectionForeground": "#5C6A72",
    "list.focusAndSelectionOutline": "#8DA10180",
    // focus not on the list::active item in the editor
    "list.inactiveSelectionBackground": "#8DA10120",
    "list.inactiveSelectionForeground": "#5C6A72",
    // focus not on the list::last selection
    "list.inactiveFocusBackground": "#F5F5F2A0",
    "list.inactiveFocusOutline": "#5C6A7220",
    // ! Notifications
    "notificationCenterHeader.background": "#EBEBE4",
    "notificationCenterHeader.foreground": "#5C6A72",
    "notifications.background": "#F5F5F2",
    "notifications.foreground": "#5C6A72",
    "notifications.border": "#8DA10180",
    // ! Panel
    //   -- position: typically below the editor, holds the "Problems", "Output", etc. panes
    // * -- core
    "panel.background": "#EBEBE4",
    "panel.border": "#00000000",
    // * -- tabs
    "panelTitle.activeBorder": "#00000000",
    "panelTitle.activeForeground": "#5C6A72",
    "panelTitle.inactiveForeground": "#5C6A72A0",
    // * -- pane "Problems"
    "problemsInfoIcon.foreground": "#3A94C5",
    "problemsWarningIcon.foreground": "#D69A00",
    "problemsErrorIcon.foreground": "#F85552",
    // ! Progress Bar
    "progressBar.background": "#8DA101",
    // ! Sash
    //   -- note: divider bar to resize adjacent UI elements
    "sash.hoverBorder": "#00000000",
    // ! Selections (Outside of the Editor)
    "selection.background": "#5C6A7240",
    // ! Settings
    // * -- general
    "settings.dropdownBackground": "#EBEBE4",
    "settings.dropdownBorder": "#5C6A7280",
    "settings.numberInputBackground": "#EBEBE4",
    "settings.numberInputBorder": "#5C6A7280",
    "settings.modifiedItemIndicator": "#3A94C5",
    "settings.textInputForeground": "#8DA101",
    "settings.textInputBorder": "#5C6A7280",
    "settings.rowHoverBackground": "#5C6A7208",
    // * -- keybinding
    "keybindingTable.headerBackground": "#EBEBE4",
    "keybindingLabel.foreground": "#5C6A72",
    "keybindingTable.rowsBackground": "#EBEBE4",
    // ! Side Bar (contains file explorer, search, etc.)
    // * -- core
    "sideBar.background": "#EBEBE4",
    "sideBar.foreground": "#5C6A72", // ~~~
    "sideBar.border": "#5C6A720C", // ~~~
    "sideBarTitle.foreground": "#5C6A72",
    "sideBarSectionHeader.background": "#00000000",
    "sideBarSectionHeader.foreground": "#5C6A72E0",
    // * -- extensions
    "extensionIcon.preReleaseForeground": "#8DA101",
    "extensionIcon.privateForeground": "#8DA101",
    "extensionIcon.starForeground": "#8DA101",
    "extensionIcon.verifiedForeground": "#8DA101",
    "extensionBadge.remoteBackground": "#5C6A72",
    "extensionBadge.remoteForeground": "#EBEBE4",
    // ! Status Bar
    //   -- position: bottom-most bar
    "statusBar.background": "#EBEBE4",
    "statusBar.foreground": "#5C6A72C0",
    "statusBar.border": "#00000000",
    "statusBarItem.hoverBackground": "#EBEBE4",
    "statusBarItem.hoverForeground": "#5C6A72",
    "statusBarItem.activeBackground": "#EBEBE4",
    "statusBarItem.remoteBackground": "#5C6A72",
    "statusBarItem.remoteForeground": "#EBEBE4",
    "statusBarItem.remoteHoverBackground": "#5C6A72",
    "statusBarItem.remoteHoverForeground": "#EBEBE4",
    "statusBar.debuggingBackground": "#EBEBE4",
    "statusBar.noFolderBackground": "#EBEBE4",
    // ! Symbols
    //   -- note: symbols are aligned with semantic token colors
    // * -- standard types
    "symbolIcon.namespaceForeground": "#35A77C",
    "symbolIcon.classForeground": "#3A94C5",
    "symbolIcon.enumeratorForeground": "#3A94C5",
    "symbolIcon.interfaceForeground": "#3A94C5",
    "symbolIcon.structForeground": "#3A94C5",
    "symbolIcon.typeParameterForeground": "#F57D26",
    "symbolIcon.variableForeground": "#5C6A72",
    "symbolIcon.propertyForeground": "#5C6A72",
    "symbolIcon.enumeratorMemberForeground": "#5C6A72",
    "symbolIcon.eventForeground": "#35A77C",
    "symbolIcon.functionForeground": "#8DA101",
    "symbolIcon.methodForeground": "#8DA101",
    "symbolIcon.stringForeground": "#D69A00",
    "symbolIcon.keywordForeground": "#F85552",
    "symbolIcon.numberForeground": "#5C6A72",
    "symbolIcon.operatorForeground": "#F57D26",
    // * -- additional types
    "symbolIcon.textForeground": "#5C6A72",
    // ! Terminal
    "terminalOverviewRuler.border": "#00000000",
    "terminal.ansiBlack": "#EBEBE4",
    "terminal.ansiBlue": "#3A94C5",
    "terminal.ansiBrightBlack": "#EBEBE4", // ~~~
    "terminal.ansiBrightBlue": "#3A94C5", // ~~~
    "terminal.ansiBrightCyan": "#35A77C", // ~~~
    "terminal.ansiBrightGreen": "#8DA101", // ~~~
    "terminal.ansiBrightMagenta": "#DF69BA", // ~~~
    "terminal.ansiBrightRed": "#F85552", // ~~~
    "terminal.ansiBrightWhite": "#5C6A72", // ~~~
    "terminal.ansiBrightYellow": "#D69A00", // ~~~
    "terminal.ansiCyan": "#35A77C",
    "terminal.ansiGreen": "#8DA101",
    "terminal.ansiMagenta": "#DF69BA",
    "terminal.ansiRed": "#F85552",
    "terminal.ansiWhite": "#5C6A72",
    "terminal.ansiYellow": "#D69A00",
    "terminal.background": "#F5F5F2",
    "terminal.foreground": "#5C6A72",
    "terminalCursor.foreground": "#5C6A72",
    // ! Testing
    // * -- icons
    "testing.iconErrored": "#F85552",
    "testing.iconFailed": "#F85552",
    "testing.iconPassed": "#8DA101",
    "testing.iconQueued": "#3A94C5",
    "testing.iconSkipped": "#DF69BA",
    "testing.iconUnset": "#5C6A72",
    "testing.runAction": "#8DA101",
    // ! Text
    // * -- monospaced
    "textPreformat.foreground": "#5C6A72",
    "textPreformat.background": "#00000000",
    // ! Title Bar
    //   -- position: top-most bar
    "titleBar.activeBackground": "#F5F5F2",
    "titleBar.activeForeground": "#5C6A72",
    "titleBar.inactiveBackground": "#F5F5F2",
    "titleBar.inactiveForeground": "#5C6A72"
  },
  // ! TEXTMATE TOKENS
  //   -- note: tokens are aligned with semantic token colors
  "tokenColors": [
    // standard semantic token types
    {
      "name": "namespace",
      "scope": "entity.name.namespace",
      "settings": {
        "foreground": "#35A77C"
      }
    },
    {
      "name": "class",
      "scope": "entity.name.class",
      "settings": {
        "foreground": "#3A94C5"
      }
    },
    {
      "name": "type",
      "scope": "entity.name.type,entity.name.type.enum,support.type,support.class",
      "settings": {
        "foreground": "#3A94C5"
      }
    },
    {
      "name": "variable",
      "scope": "variable,variable.parameter,variable.language",
      "settings": {
        "foreground": "#5C6A72"
      }
    },
    {
      "name": "Property",
      "scope": "meta.attribute",
      "settings": {
        "foreground": "#5C6A72"
      }
    },
    {
      "name": "Decorator",
      "scope": "entity.name.function.decorator",
      "settings": {
        "foreground": "#8DA101"
      }
    },
    {
      "name": "function",
      "scope": "entity.name.function,support.function,meta.function-call",
      "settings": {
        "foreground": "#8DA101"
      }
    },
    {
      "name": "method",
      "scope": "entity.name.method",
      "settings": {
        "foreground": "#8DA101"
      }
    },
    {
      "name": "macro",
      "scope": "entity.name.function.macro",
      "settings": {
        "foreground": "#DF69BA"
      }
    },
    {
      "name": "comment",
      "scope": "comment,string.comment,punctuation.definition.comment,punctuation.definition.tag.begin,punctuation.definition.tag.end,string.quoted.docstring",
      "settings": {
        "foreground": "#5C6A72A0" // ~~~
      }
    },
    {
      "name": "string",
      "scope": "string",
      "settings": {
        "foreground": "#D69A00"
      }
    },
    {
      "name": "keyword",
      "scope": "keyword,keyword.control,keyword.operator,storage,storage.modifier,storage.type",
      "settings": {
        "foreground": "#F85552"
      }
    },
    {
      "name": "operator",
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#F57D26"
      }
    },
    // custom semantic token types
