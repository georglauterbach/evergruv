{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Generate Theme",
      "type": "shell",
      "command": "./generate.sh",
      "args": [
        "${input:variant}"
      ],
      "problemMatcher": [],
      "runOptions": {
        "instanceLimit": 1
      },
      "presentation": {
        "echo": false,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    }
  ],
  "inputs": [
    {
      "id": "variant",
      "description": "Which theme variant to create",
      "type": "pickString",
      "options": [
        "light",
        "dark"
      ],
      "default": "light"
    }
  ]
}
